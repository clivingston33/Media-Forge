{
  "name": "mediaforge",
  "private": true,
  "version": "0.1.4",
  "description": "MediaForge desktop media toolkit",
  "author": "MediaForge contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "generate:icons": "..\\backend\\.venv312\\Scripts\\python scripts\\generate_icons.py",
    "generate:runtime-config": "node scripts\\generate_runtime_config.mjs",
    "stage:backend-runtime": "node scripts\\stage_backend_runtime.mjs",
    "build:web": "tsc -b && vite build",
    "build:electron": "node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json",
    "build": "npm run generate:runtime-config && npm run build:web && npm run build:electron",
    "desktop": "npm run build && electron .",
    "dist:dir": "npm run generate:icons && npm run build && npm run stage:backend-runtime && electron-builder --dir",
    "dist:win": "npm run generate:icons && npm run build && npm run stage:backend-runtime && electron-builder --win nsis",
    "dist:release": "npm run generate:icons && npm run build && npm run stage:backend-runtime && electron-builder --config electron-builder.release.yml --win nsis --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sentry/electron": "^7.10.0",
    "ajv": "^6.14.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.3"
  }
}
